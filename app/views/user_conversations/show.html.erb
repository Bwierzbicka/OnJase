<% @user_conversation.user_conversation_messages.each do |message| %>
<%= message.content %>
<% end %>
<%= simple_form_for [@user_conversation, @user_conversation_message] do |f| %>
    <%= f.input :content, placeholder: "Ask anything", required: true, label: false %>
    <%= f.button :submit, "Submit", class: "btn btn-primary" %>
  <% end %>
