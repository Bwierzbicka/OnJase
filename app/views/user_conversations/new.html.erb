<h2>Start a Conversation</h2>

<%= form_with model: @user_conversation do |f| %>
  <%= f.hidden_field :user_id_1, value: current_user.id %>

  <div>
    <%= f.label :user_id_2, "User ID to message" %>
    <%= f.number_field :user_id_2, placeholder: "Enter user ID", required: true %>
  </div>

  <%= f.submit "Start Conversation" %>
<% end %>
